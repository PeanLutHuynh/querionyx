# PostgreSQL containing the Northwind schema
PGHOST=localhost
PGPORT=5432
PGDATABASE=northwind
PGUSER=postgres
PGPASSWORD=change-me
PGSSLMODE=prefer

# Reproducible public-demo mode; Ollama is not required
QUERIONYX_EXECUTION_MODE=demo_no_ollama
ENABLE_HEAVY_RAG=0
QUERIONYX_LIGHTWEIGHT_RAG=1
QUERIONYX_PREWARM_RETRIEVAL=1
QUERIONYX_CACHE_ENABLED=1
QUERIONYX_MERGE_LLM_ENABLED=0
QUERIONYX_USE_LLM_ROUTER=0
QUERIONYX_RAG_LOW_CONFIDENCE_THRESHOLD=0.6
QUERIONYX_LIGHTWEIGHT_RAG_MS=4000
QUERIONYX_SQL_EXECUTION_MS=5000
QUERIONYX_END_TO_END_MS=10000
QUERIONYX_MAX_CONCURRENCY=2

# Frontend and optional local-research services
NEXT_PUBLIC_API_BASE=http://localhost:8000
OLLAMA_BASE_URL=http://127.0.0.1:11434
